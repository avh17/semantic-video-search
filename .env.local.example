# Convex deployment configuration
# Get these from https://dashboard.convex.dev after creating a project
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# OpenAI API key for Whisper transcription and embeddings
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=

# ScrapeCreators API key for Instagram video extraction (pay-as-you-go)
# Sign up at https://app.scrapecreators.com to get free 100 credits
# Pricing: Free 100 credits, then $10 for 5,000 credits (never expire)
# Cost: 1 credit per video URL extraction
SCRAPECREATORS_API_KEY=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
